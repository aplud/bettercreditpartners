# ──────────────────────────────────────────────────
# BCP Partner Portal — Environment Variables
# ──────────────────────────────────────────────────

# Required in production
DATABASE_URL=postgresql://user:password@localhost:5432/bcp
SESSION_SECRET=generate-a-random-64-char-string-here
NODE_ENV=development

# Server
PORT=5000

# SignNow — Partner agreement e-signing
SIGNNOW_API_KEY=your-signnow-api-key
SIGNNOW_TEMPLATE_ID=your-signnow-template-id

# Email notifications (Resend — free tier: 100 emails/day)
RESEND_API_KEY=your-resend-api-key

# Admin notification email (where new lead alerts are sent)
ADMIN_NOTIFICATION_EMAIL=aaron@bettercreditpartners.com

# Google Sheets sync (optional)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
